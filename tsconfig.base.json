{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@liteforge/core": ["./packages/core/src/index.ts"],
      "@liteforge/core/*": ["./packages/core/src/*"],
      "@liteforge/runtime": ["./packages/runtime/src/index.ts"],
      "@liteforge/runtime/*": ["./packages/runtime/src/*"],
      "@liteforge/store": ["./packages/store/src/index.ts"],
      "@liteforge/store/*": ["./packages/store/src/*"],
      "@liteforge/router": ["./packages/router/src/index.ts"],
      "@liteforge/router/*": ["./packages/router/src/*"],
      "@liteforge/transform": ["./packages/transform/src/index.ts"],
      "@liteforge/transform/*": ["./packages/transform/src/*"],
      "@liteforge/vite-plugin": ["./packages/vite-plugin/src/index.ts"],
      "@liteforge/vite-plugin/*": ["./packages/vite-plugin/src/*"],
      "@liteforge/devtools": ["./packages/devtools/src/index.ts"],
      "@liteforge/devtools/*": ["./packages/devtools/src/*"],
      "@liteforge/client": ["./packages/client/src/index.ts"],
      "@liteforge/client/*": ["./packages/client/src/*"],
      "@liteforge/query": ["./packages/query/src/index.ts"],
      "@liteforge/query/*": ["./packages/query/src/*"],
      "@liteforge/form": ["./packages/form/src/index.ts"],
      "@liteforge/form/*": ["./packages/form/src/*"],
      "@liteforge/table": ["./packages/table/src/index.ts"],
      "@liteforge/table/*": ["./packages/table/src/*"],
      "@liteforge/modal": ["./packages/modal/src/index.ts"],
      "@liteforge/modal/*": ["./packages/modal/src/*"],
      "@liteforge/calendar": ["./packages/calendar/src/index.ts"],
      "@liteforge/calendar/*": ["./packages/calendar/src/*"],
      "@liteforge/theme": ["./packages/theme/src/index.ts"],
      "@liteforge/theme/*": ["./packages/theme/src/*"],
      "@liteforge/toast": ["./packages/toast/src/index.ts"],
      "@liteforge/toast/*": ["./packages/toast/src/*"],
      "@liteforge/flow": ["./packages/flow/src/index.ts"],
      "@liteforge/flow/*": ["./packages/flow/src/*"]
    },
    "noUncheckedIndexedAccess": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true
  }
}
