{
  "name": "liteforge-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r typecheck",
    "build:packages": "pnpm --filter './packages/*' build",
    "build:apps": "pnpm --filter './examples/*' build",
    "build": "pnpm build:packages && pnpm build:apps",
    "dev": "pnpm --filter @liteforge/starter dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r exec rm -rf dist",
    "clean:all": "pnpm clean && rm -rf node_modules",
    "prepublish:check": "pnpm clean && pnpm build:packages && pnpm test:run && pnpm typecheck:all",
    "publish:all": "pnpm prepublish:check && pnpm -r publish --access public",
    "publish:dry": "pnpm prepublish:check && pnpm -r publish --access public --dry-run",
    "version:patch": "pnpm -r --filter './packages/*' exec npm version patch",
    "version:minor": "pnpm -r --filter './packages/*' exec npm version minor"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
