    it('sets nested field values', () => {
      const form = createForm({
        schema: z.object({
          address: z.object({
            street: z.string(),
            city: z.string(),
          }),
        }),
        initial: {
          address: { street: '', city: '' },
        },
        onSubmit: vi.fn(),
      });

      form.field('address.street').set('456 Oak Ave');
      expect(form.field('address.street').value()).toBe('456 Oak Ave');
      expect(form.values().address.street).toBe('456 Oak Ave');
