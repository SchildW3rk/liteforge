{
  "name": "@liteforge/form",
  "version": "0.0.1",
  "description": "LiteForge signals-based form management with Zod validation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@liteforge/core": "workspace:*",
    "zod": "^3.0.0"
  },
  "keywords": [
    "liteforge",
    "form",
    "validation",
    "zod",
    "signals",
    "reactive"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liteforge/liteforge.git",
    "directory": "packages/form"
  }
}
