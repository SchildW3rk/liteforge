{
  "name": "@liteforge/calendar",
  "version": "0.4.0",
  "description": "Full scheduling calendar with day/week/month/agenda views, drag & drop, resize, and resource columns.",
  "author": "SchildW3rk <contact@schildw3rk.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schildw3rk/liteforge",
    "directory": "packages/calendar"
  },
  "homepage": "https://github.com/schildw3rk/liteforge#readme",
  "bugs": {
    "url": "https://github.com/schildw3rk/liteforge/issues"
  },
  "keywords": [
    "liteforge",
    "calendar",
    "scheduler",
    "scheduling",
    "events",
    "resources",
    "drag-drop",
    "signals",
    "reactive"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./css/styles.css"
  },
  "files": [
    "dist",
    "css",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "css/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@liteforge/core": ">=0.1.0"
  },
  "devDependencies": {
    "@liteforge/core": "workspace:*"
  }
}
